{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["name", "email"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Educational subjects being studied",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "name": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "name", "timestamp"]
    },
    "TimetableSession": {
      "title": "Timetable Session",
      "description": "A scheduled class or study period",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "loc": { "type": "string" },
        "day_of_week": { "type": "string", "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"] },
        "start_time": { "type": "string" },
        "end_time": { "type": "string" },
        "start": { "type": "number" },
        "end": { "type": "number" },
        "user_id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "loc", "day_of_week", "start_time", "end_time", "start", "end", "user_id", "timestamp"]
    },
    "Task": {
      "title": "Task",
      "description": "A study task or assignment",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "status": { "type": "string", "enum": ["To Do", "In Progress", "Completed", "Overdue"] },
        "dueDate": { "type": "string" },
        "progress": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "title", "subject", "priority", "status", "dueDate", "progress", "timestamp"]
    },
    "Note": {
      "title": "Note",
      "description": "Study notes with attachments",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "pinned": { "type": "boolean" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "attachments": { "type": "array" },
        "user_id": { "type": "string" }
      },
      "required": ["title", "subject", "content", "timestamp", "pinned", "tags", "attachments", "user_id"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "User profiles" },
    "subjects": { "schema": "Subject", "description": "Academic subjects" },
    "timetable": { "schema": "TimetableSession", "description": "Scheduled sessions" },
    "tasks": { "schema": "Task", "description": "To-do items" },
    "notes": { "schema": "Note", "description": "Study notes" }
  }
}
